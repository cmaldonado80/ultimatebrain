# ── Required ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ultimatebrain
AUTH_SECRET=your-jwt-secret-at-least-32-chars  # Required in production

# ── LLM Providers (at least one required) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── Optional: Local Models ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
DEFAULT_MODEL=qwen3-coder:480b-cloud  # Override default LLM model

# ── Optional: Encryption ─────────────────────────────────────────────────
VAULT_SECRET=generate-a-random-32-char-string  # Encrypts API keys + DB URLs at rest

# ── Optional: Neon (Mini-Brain provisioning) ──────────────────────────────
NEON_API_KEY=
NEON_PROJECT_ID=

# ── Optional: OpenClaw Daemon ────────────────────────────────────────────
OPENCLAW_WS=ws://127.0.0.1:18789      # WebSocket URL to OpenClaw daemon
OPENCLAW_TOKEN=                         # Auth token (if daemon requires it)

# ── Optional: Cron Security ──────────────────────────────────────────────
CRON_SECRET=  # Vercel cron jobs verify this via Authorization header

# ── Optional: A2A Protocol ───────────────────────────────────────────────
A2A_ALLOWED_ORIGINS=*  # Comma-separated origins, or * for all

# ── Optional: Integrations ──────────────────────────────────────────────
NOTION_API_KEY=                        # For Notion tool integration
SLACK_WEBHOOK_URL=                     # For Slack notification delivery
WEBHOOK_AGENT_SECRET=                  # Auth secret for /api/webhooks/agent

# ── Optional: Brain SDK (Mini-Brains connecting to this Brain) ───────────
BRAIN_URL=http://localhost:3000        # This Brain's URL (for Mini Brain SDK)
BRAIN_API_KEY=                         # API key for Mini Brain authentication

# ── Optional: Observability ──────────────────────────────────────────────
DB_SLOW_QUERY_THRESHOLD=500            # ms threshold for slow query warnings

# ── System ───────────────────────────────────────────────────────────────
BRAIN_NAME=Solarc Brain
BRAIN_VERSION=0.1.0
NODE_ENV=development

# ── Development Only ─────────────────────────────────────────────────────
SKIP_AUTH=true  # Bypasses auth — IGNORED in production
