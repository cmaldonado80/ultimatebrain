# ── Required ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ultimatebrain
AUTH_SECRET=your-jwt-secret-at-least-32-chars  # Required in production

# ── LLM Providers (at least one required) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── Optional: Local Models ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# ── Optional: Neon (Mini-Brain provisioning) ──────────────────────────────
NEON_API_KEY=
NEON_PROJECT_ID=

# ── Optional: OpenClaw Daemon ────────────────────────────────────────────
OPENCLAW_WS=ws://127.0.0.1:18789      # WebSocket URL to OpenClaw daemon
OPENCLAW_TOKEN=                         # Auth token (if daemon requires it)

# ── Optional: Cron Security ──────────────────────────────────────────────
CRON_SECRET=  # Vercel cron jobs verify this via Authorization header

# ── Optional: A2A Protocol ───────────────────────────────────────────────
A2A_ALLOWED_ORIGINS=*  # Comma-separated origins, or * for all

# ── Sentry Error Monitoring ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── System ───────────────────────────────────────────────────────────────
BRAIN_NAME=Solarc Brain
BRAIN_VERSION=0.1.0
NODE_ENV=development

# ── Development Only ─────────────────────────────────────────────────────
SKIP_AUTH=true  # Bypasses auth — IGNORED in production
