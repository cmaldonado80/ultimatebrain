# Solarc Brain — Environment Variables
# Copy to .env.local and fill in values

# Postgres (pgvector)
DATABASE_URL=postgres://postgres:dev@localhost:5432/solarc

# OpenClaw daemon
OPENCLAW_WS=ws://localhost:18789

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# LLM API Keys (encrypted at rest in api_keys table, these are for initial setup)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Brain SDK (for Mini Brains connecting to this Brain)
BRAIN_API_KEY=
BRAIN_URL=http://localhost:3000

# Node
NODE_ENV=development
