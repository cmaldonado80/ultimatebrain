# Solarc Brain — Environment Variables
# Copy to .env.local and fill in values
#
# Variables marked [required] must be set. Others have sensible defaults
# or are optional. See apps/web/src/env.ts for the validation schema.

# ── Database (required) ───────────────────────────────────────
DATABASE_URL=postgres://postgres:dev@localhost:5432/solarc

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Key Vault (min 16 chars, required for API-key encryption) ─
VAULT_SECRET=

# ── Brain identity ────────────────────────────────────────────
BRAIN_VERSION=1.0.0
BRAIN_NAME=UltimateBrain

# ── Brain SDK (for Mini Brains connecting to this Brain) ──────
BRAIN_API_KEY=
BRAIN_URL=http://localhost:3000

# ── OpenClaw daemon ───────────────────────────────────────────
OPENCLAW_WS=ws://localhost:18789

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── LLM API Keys (encrypted at rest, these are for initial setup)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Public (exposed to the browser via Next.js) ──────────────
NEXT_PUBLIC_API_BASE_URL=
