# Solarc Brain — Environment Variables
# Copy to .env.local and fill in values
#
# Variables marked [required] must be set. Others have sensible defaults
# or are optional. See apps/web/src/env.ts for the validation schema.

# ── Database (required) ───────────────────────────────────────
DATABASE_URL=postgres://postgres:dev@localhost:5432/solarc

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development

# ── NextAuth (required) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional: defaults to http://localhost:3000
AUTH_URL=http://localhost:3000

# ── OAuth Providers (optional — enable by setting both ID + Secret) ──
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Key Vault (required for API-key encryption) ─────────────
# Generate with: openssl rand -hex 16   (min 16 chars)
VAULT_SECRET=

# ── Brain identity ────────────────────────────────────────────
BRAIN_VERSION=1.0.0
BRAIN_NAME=UltimateBrain

# ── Brain SDK (for Mini Brains connecting to this Brain) ──────
BRAIN_API_KEY=
BRAIN_URL=http://localhost:3000

# ── OpenClaw daemon ───────────────────────────────────────────
OPENCLAW_WS=ws://localhost:18789
OPENCLAW_TOKEN=

# ── Ollama (local or cloud) ─────────────────────────────────
# Local: http://localhost:11434 (default, no auth needed)
# Cloud: https://ollama.com/api (requires API key from ollama.com/settings/keys)
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# ── Cron Security ────────────────────────────────────────────
# Required in production to secure the /api/cron endpoint
CRON_SECRET=

# ── Development ──────────────────────────────────────────────
# Set to 'true' ONLY in local development to bypass auth
# SKIP_AUTH=true

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── LLM API Keys (encrypted at rest, these are for initial setup)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Sentry Error Monitoring ──────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Public (exposed to the browser via Next.js) ──────────────
NEXT_PUBLIC_API_BASE_URL=
