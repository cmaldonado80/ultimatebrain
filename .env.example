# ─── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Authentication ────────────────────────────────────────────
AUTH_SECRET=generate-a-random-32-char-string-here
# Set to "true" to skip auth in development
SKIP_AUTH=false

# ─── Encryption ────────────────────────────────────────────────
VAULT_SECRET=generate-a-random-32-char-string-here

# ─── LLM Providers (at least one required for chat) ───────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://localhost:11434

# ─── Cron Security ────────────────────────────────────────────
CRON_SECRET=generate-a-random-16-char-string-here

# ─── Optional: A2A Cross-Origin ────────────────────────────────
# Comma-separated origins. Empty = deny cross-origin in production.
# A2A_ALLOWED_ORIGINS=https://app1.example.com,https://app2.example.com

# ─── Optional: Neon Database API ───────────────────────────────
# NEON_API_KEY=napi_...

# ─── Optional: Vercel ──────────────────────────────────────────
# VERCEL_TOKEN=vck_...
