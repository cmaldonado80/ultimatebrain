{
  "mcpServers": {
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus@latest", "mcp"],
      "env": {}
    },
    "ruflo": {
      "command": "npx",
      "args": ["-y", "ruflo@latest", "serve"],
      "env": {}
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "$DATABASE_URL"],
      "env": {}
    }
  }
}
